# ── Active provider ───────────────────────────────────────────────────────
# One of: liteparse | llamaparse | openai | gemini | anthropic
ACTIVE_PROVIDER=liteparse

# ── Provider API keys (fill whichever providers you want to use) ──────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIzaSy...
LLAMA_CLOUD_API_KEY=llx-...

# ── Infrastructure ────────────────────────────────────────────────────────
# Docker Compose: MONGODB_URL is overridden to mongodb://mongo:27017 in compose
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=pdf_agent

# Upload directory (overridden to /app/uploads in Docker)
UPLOAD_DIR=/tmp/pdf_uploads

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (for local dev outside Docker)
CORS_ORIGINS=["http://localhost:5173"]
